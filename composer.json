{
    "name": "hacklabr/ai-assistant",
    "description": "Embeddable AI assistant framework for PHP built on Neuron AI",
    "type": "library",
    "license": "MIT",
    "keywords": ["ai", "assistant", "agent", "llm", "neuron", "mcp"],
    "authors": [
        {
            "name": "HackLab",
            "email": "dev@hacklab.com.br"
        }
    ],
    "require": {
        "php": "^8.3",
        "neuron-core/neuron-ai": "^3.0",
        "psr/log": "^2.0 || ^3.0",
        "smalot/pdfparser": "^2.12",
        "phpoffice/phpword": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "HackLab\\AIAssistant\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HackLab\\AIAssistant\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
